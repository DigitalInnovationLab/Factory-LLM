# ============================================================
# F-LLM Environment Variables — copy to .env and fill in values
# ============================================================

# --- Application ---
APP_ENV=development        

# --- MySQL Database ---
MYSQL_PASSWORD=your_mysql_password
# Sync connection (used by Alembic migrations) — uses PyMySQL driver
DB_CONNECTION_SYNC=mysql+pymysql://root:your_mysql_password@127.0.0.1:3306/f-llm
# Async connection (used by the application runtime)
DB_CONNECTION=mysql+asyncmy://root:your_mysql_password@127.0.0.1:3306/f-llm

# --- ChromaDB (Vector Store) ---
CHROMA_HOST=127.0.0.1
CHROMA_PORT=8000
CHROMA_TOKEN=your_chroma_auth_token
CHROMA_SERVER_AUTHN_CREDENTIALS=your_chroma_auth_token

# --- NebulaGraph (Knowledge Graph Store) ---
NEBULA_USER=root
NEBULA_PASSWORD=nebula
NEBULA_ADDRESS=127.0.0.1:9669

# --- LLM API Keys ---
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...
OPENROUTER_API_KEY=sk-or-...

# --- Optional ---
GROQ_API_KEY=gsk_...
